{
  "name": "@meteorlxy/create",
  "version": "4.2.4",
  "description": "Create JavaScript Project",
  "keywords": [
    "create",
    "scaffolding"
  ],
  "homepage": "https://github.com/meteorlxy/create#readme",
  "bugs": {
    "url": "https://github.com/meteorlxy/create/issues"
  },
  "license": "MIT",
  "author": "meteorlxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meteorlxy/create.git"
  },
  "bin": {
    "create": "./bin/create.mjs"
  },
  "files": [
    "bin",
    "lib",
    "templates"
  ],
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "imports": {
    "#templates/*": "./templates/*"
  },
  "exports": {
    ".": "./lib/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib *.tsbuildinfo",
    "dev": "pnpm build && pnpm dev:clean && node bin/create.mjs dev",
    "dev:clean": "rimraf dev",
    "format": "oxfmt",
    "lint": "eslint . && oxfmt --check && ls-lint",
    "lint:fix": "eslint . --fix && oxfmt",
    "prepare": "husky",
    "release": "pnpm release:check && pnpm release:version",
    "release:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:check": "pnpm clean && pnpm build && pnpm lint",
    "release:version": "bumpp --execute=\"pnpm release:changelog\" --commit \"build: publish v%s\" --all"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ejs": "^5.0.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "lodash.merge": "^4.6.2",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "sort-package-json": "^3.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@ls-lint/ls-lint": "^2.3.1",
    "@meteorlxy/create": "link:",
    "@meteorlxy/eslint-config": "^7.1.0",
    "@meteorlxy/oxfmt-config": "^7.1.0",
    "@meteorlxy/tsconfig": "^6.8.5",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "bumpp": "^11.0.1",
    "conventional-changelog": "^7.2.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.(js|mjs|mts)": [
      "eslint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.!(js|mjs|mts)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.32.1"
}
